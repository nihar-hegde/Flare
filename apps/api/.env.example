# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:3000

# Shared secret accepted by POST /api/ingest.
# Send it as either `Authorization: Bearer <key>` or `x-flare-api-key: <key>`.
INGEST_API_KEY=dev-flare-ingest-key

# ─────────────────────────────────────────────────────────────
# GitHub Code Context (MVP token-based sync)
# ─────────────────────────────────────────────────────────────
# Fine-grained PAT, repo-scoped, read-only:
# Contents: Read, Metadata: Read, Pull requests: Read, Commit statuses: Read.
GITHUB_TOKEN=github_pat_...
GITHUB_OWNER=nihar-hegde
GITHUB_REPO=flare-demo-payments-api
GITHUB_DEFAULT_BRANCH=main

# ─────────────────────────────────────────────────────────────
# Supabase / Postgres (Drizzle)
# ─────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL  = runtime connection. Use the "Transaction" pooler (port 6543).
#                 pgBouncer-friendly, what the Hono server uses per-request.
# DIRECT_URL    = migrations connection. Use the "Session"/direct conn (port 5432).
#                 Drizzle Kit needs a non-pooled connection to run migrations.
#
# Replace [PROJECT-REF], [PASSWORD], and [REGION] with your project's values.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Supabase API keys — only needed if you use supabase-js (auth/storage/realtime).
# Pure Drizzle access does NOT need these. Dashboard → Project Settings → API.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, NEVER expose to the browser

# ─────────────────────────────────────────────────────────────
# AI Investigation Engine (Vercel AI SDK — provider-agnostic)
# ─────────────────────────────────────────────────────────────
# The engine uses the `ai` package, so providers are swappable per-task.
# Only the keys for providers you actually use need to be set.

# Active now (using up existing OpenAI credits). platform.openai.com → API keys
OPENAI_API_KEY=sk-...

# Ready to switch on later — uncomment and the model registry picks them up.
# ANTHROPIC_API_KEY=sk-ant-...        # console.anthropic.com
# GOOGLE_GENERATIVE_AI_API_KEY=...    # aistudio.google.com  (Gemini Flash, etc.)

# Per-task model routing. Change provider/model without touching code.
# Format: "<provider>:<model>"  e.g. openai:gpt-4o, anthropic:claude-opus-4-8
INVESTIGATOR_MODEL=openai:gpt-4o
SUMMARIZER_MODEL=openai:gpt-4o-mini
